:root {
  --jagwa-black: #05090d;
  --jagwa-dark: #071117;
  --jagwa-card: #111820;
  --jagwa-teal: #007d87;
  --jagwa-teal-light: #00a6b3;
  --jagwa-red: #f0141e;
  --jagwa-red-dark: #b90f18;
  --jagwa-white: #ffffff;
  --jagwa-page: #f5f7fb;
  --jagwa-text: #0f172a;
  --jagwa-muted: #64748b;
  --jagwa-border: rgba(15, 23, 42, 0.08);
  --jagwa-shadow: 0 18px 45px rgba(15, 23, 42, 0.10);
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  min-height: 100vh;
  font-family: Inter, Arial, sans-serif;
  background: var(--jagwa-page);
  color: var(--jagwa-text);
}

button,
input,
select,
textarea {
  font: inherit;
}

a {
  color: inherit;
}

.visually-hidden {
  display: none !important;
}

.text-muted {
  color: var(--jagwa-muted) !important;
}

.text-danger {
  color: #b91c1c !important;
}

.small {
  font-size: 13px;
}

.bg-white {
  background: #ffffff !important;
}

.mb-1 { margin-bottom: 4px !important; }
.mb-2 { margin-bottom: 8px !important; }
.mb-3 { margin-bottom: 12px !important; }
.mb-4 { margin-bottom: 18px !important; }
.mt-1 { margin-top: 4px !important; }
.mt-2 { margin-top: 8px !important; }

.d-flex {
  display: flex !important;
}

.align-items-center {
  align-items: center !important;
}

.align-items-start {
  align-items: flex-start !important;
}

.justify-content-between {
  justify-content: space-between !important;
}

.gap-3 {
  gap: 12px !important;
}

.rounded-4 {
  border-radius: 22px !important;
}

.shadow-sm {
  box-shadow: var(--jagwa-shadow) !important;
}

.p-4 {
  padding: 24px !important;
}

/* =========================================================
   VOTER LAYOUT
========================================================= */

.voter-layout {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 280px 1fr;
  background: var(--jagwa-page);
}

.voter-sidebar {
  background:
    radial-gradient(circle at bottom right, rgba(0, 125, 135, 0.35), transparent 35%),
    linear-gradient(180deg, #020607 0%, #071117 100%);
  color: white;
  padding: 28px 22px;
  border-right: 1px solid rgba(255,255,255,0.08);
  position: sticky;
  top: 0;
  min-height: 100vh;
}

.brand-box {
  display: flex !important;
  align-items: center !important;
  gap: 14px !important;
  margin-bottom: 40px !important;
  padding: 14px !important;
  background: rgba(255,255,255,0.035) !important;
  border: 1px solid rgba(255,255,255,0.08) !important;
  border-radius: 20px !important;
}

.brand-logo {
  width: 54px !important;
  height: 54px !important;
  min-width: 54px !important;
  max-width: 54px !important;
  object-fit: contain !important;
  object-position: center !important;
  background: transparent !important;
  border-radius: 0 !important;
  padding: 0 !important;
  box-shadow: none !important;
  border: none !important;
}

.brand-box h3 {
  margin: 0 !important;
  font-size: 18px !important;
  letter-spacing: 4px !important;
  font-weight: 900 !important;
  line-height: 1.05 !important;
  color: var(--jagwa-teal-light) !important;
}

.brand-box h3 span {
  display: block !important;
  color: var(--jagwa-red) !important;
}

.voter-menu {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.voter-menu a {
  color: rgba(255,255,255,0.88);
  text-decoration: none;
  padding: 15px 18px;
  border-radius: 16px;
  font-weight: 800;
  display: flex;
  align-items: center;
  gap: 10px;
  transition: 0.2s ease;
}

.voter-menu a:hover {
  background: rgba(0, 166, 179, 0.16);
  color: white;
}

.voter-menu a.active {
  background: linear-gradient(135deg, var(--jagwa-red), var(--jagwa-red-dark));
  color: white;
  box-shadow: 0 14px 30px rgba(240, 20, 30, 0.25);
}

.vote-note {
  margin-top: 60px;
  background:
    radial-gradient(circle at bottom right, rgba(0, 166, 179, 0.25), transparent 40%),
    rgba(255,255,255,0.045);
  border: 1px solid rgba(0, 166, 179, 0.25);
  border-radius: 22px;
  padding: 24px;
  color: white;
}

.vote-note strong {
  display: block;
  margin-bottom: 10px;
  font-size: 16px;
}

.vote-note p {
  margin: 0;
  line-height: 1.7;
  color: rgba(255,255,255,0.72);
}

.voter-main {
  padding: 32px 38px;
  background:
    radial-gradient(circle at top right, rgba(0, 166, 179, 0.08), transparent 30%),
    var(--jagwa-page);
}

.voter-topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 22px;
  margin-bottom: 28px;
}

.voter-topbar h1 {
  margin: 0;
  color: var(--jagwa-text);
  font-size: 34px;
  font-weight: 900;
  letter-spacing: -0.04em;
}

.voter-topbar p {
  margin: 6px 0 0;
  color: var(--jagwa-muted);
  font-size: 16px;
}

/* =========================================================
   AUTH + PROFILE
========================================================= */

#authStatus {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}

.guest-text {
  color: var(--jagwa-muted);
  font-weight: 800;
}

.voter-mini-profile {
  background: linear-gradient(135deg, #0e2230, #123848);
  border: 1px solid rgba(79, 209, 224, 0.18);
  border-radius: 18px;
  padding: 12px 16px;
  min-width: 220px;
  box-shadow: 0 12px 26px rgba(0,0,0,0.16);
}

.voter-mini-info strong {
  display: block;
  color: #ffffff;
  font-size: 15px;
  font-weight: 900;
  margin-bottom: 3px;
}

.voter-mini-info small {
  display: block;
  color: #dbeafe;
  font-size: 13px;
  font-weight: 700;
}

.voter-profile-card {
  background: linear-gradient(135deg, #0f2230, #174254);
  border: 1px solid rgba(79, 209, 224, 0.18);
  border-radius: 24px;
  padding: 20px;
  box-shadow: 0 18px 40px rgba(0,0,0,0.16);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18px;
  flex-wrap: wrap;
}

.voter-profile-left {
  display: flex;
  align-items: center;
}

.voter-profile-text h3 {
  margin: 0 0 6px;
  color: white;
  font-size: 24px;
  font-weight: 900;
}

.voter-profile-text p {
  margin: 0;
  color: #dbeafe;
  font-size: 16px;
  font-weight: 700;
}

.voter-profile-actions {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}

.voter-profile-badge {
  background: rgba(255,255,255,0.12);
  color: white;
  padding: 10px 14px;
  border-radius: 999px;
  font-size: 13px;
  font-weight: 900;
}

.btn-logout {
  border: none !important;
  background: linear-gradient(135deg, #ef4444, #b91c1c) !important;
  color: white !important;
  border-radius: 999px !important;
  padding: 11px 18px !important;
  font-weight: 900 !important;
  cursor: pointer;
  box-shadow: 0 10px 20px rgba(239, 68, 68, 0.25);
  transition: 0.2s ease;
}

.btn-logout:hover {
  transform: translateY(-1px);
  opacity: 0.95;
}

/* =========================================================
   ALERTS + BUTTONS
========================================================= */

.alert {
  border-radius: 18px !important;
  border: none !important;
  padding: 15px 18px !important;
  margin-bottom: 18px;
  line-height: 1.6;
}

.alert-info {
  background: rgba(0, 166, 179, 0.12) !important;
  color: #075985 !important;
}

.alert-warning {
  background: #fff7ed !important;
  color: #9a3412 !important;
}

.alert-danger {
  background: #fee2e2 !important;
  color: #991b1b !important;
}

.btn,
.btn-primary,
.vote-button,
button[type="submit"],
.print-my-votes button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--jagwa-red), var(--jagwa-red-dark)) !important;
  color: white !important;
  border: none !important;
  border-radius: 14px !important;
  padding: 12px 18px !important;
  font-weight: 900 !important;
  text-decoration: none !important;
  box-shadow: 0 14px 30px rgba(240, 20, 30, 0.22);
  cursor: pointer;
  transition: 0.2s ease;
}

.btn:hover,
.btn-primary:hover,
.vote-button:hover,
button[type="submit"]:hover,
.print-my-votes button:hover {
  transform: translateY(-2px);
}

button:disabled,
.vote-button:disabled {
  opacity: 0.65;
  cursor: not-allowed;
  transform: none !important;
}

/* =========================================================
   DASHBOARD
========================================================= */

.progress-card,
.info-card,
.loading-card {
  background: white;
  border: 1px solid var(--jagwa-border);
  border-radius: 24px;
  padding: 28px;
  box-shadow: var(--jagwa-shadow);
  margin-bottom: 24px;
}

.progress-card h3,
.info-card h3 {
  margin-top: 0;
  font-weight: 900;
  color: var(--jagwa-text);
}

.progress-content {
  display: flex;
  align-items: center;
  gap: 28px;
}

.circle-progress {
  width: 130px;
  height: 130px;
  border-radius: 50%;
  background:
    radial-gradient(circle at center, #ffffff 52%, transparent 53%),
    conic-gradient(var(--jagwa-teal-light) 0deg, #e5e7eb 0deg);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-shadow: inset 0 0 0 12px rgba(0, 125, 135, 0.06);
}

.circle-progress span {
  font-size: 30px;
  font-weight: 900;
  color: var(--jagwa-text);
}

.circle-progress small {
  color: var(--jagwa-muted);
  font-weight: 800;
}

#progressText {
  margin: 0;
  font-size: 34px;
  font-weight: 900;
}

#progressMessage {
  color: var(--jagwa-muted);
}

.dashboard-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 22px;
}

.info-card h3 {
  color: var(--jagwa-teal);
}

.info-card.warning h3 {
  color: var(--jagwa-red);
}

.info-card p {
  color: #475569;
  line-height: 1.7;
}

/* =========================================================
   VOTE PAGE
========================================================= */

#positions {
  display: flex;
  flex-direction: column;
  gap: 22px;
}

.position-card {
  background: white !important;
  border: 1px solid var(--jagwa-border) !important;
  border-radius: 24px !important;
  padding: 24px;
  box-shadow: var(--jagwa-shadow) !important;
}

.position-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18px;
  margin-bottom: 18px;
}

.position-card h5 {
  margin: 0 0 6px;
  font-size: 22px;
  font-weight: 900;
  color: var(--jagwa-text);
}

.position-card p {
  margin: 0;
  color: var(--jagwa-muted);
}

.position-label {
  background: rgba(0, 166, 179, 0.12) !important;
  color: var(--jagwa-teal) !important;
  border-radius: 999px;
  padding: 8px 14px;
  font-weight: 900;
  white-space: nowrap;
}

.candidate-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
}

.candidate-card {
  background: white;
  border: 1px solid rgba(15, 23, 42, 0.10);
  border-radius: 20px;
  padding: 14px;
  display: flex;
  gap: 14px;
  min-height: 160px;
  transition: 0.2s ease;
  overflow: hidden;
}

.candidate-card:hover {
  border-color: rgba(0, 166, 179, 0.45);
  box-shadow: 0 12px 28px rgba(0, 125, 135, 0.12);
  transform: translateY(-2px);
}

.candidate-photo {
  width: 110px !important;
  height: 130px !important;
  min-width: 110px !important;
  max-width: 110px !important;
  border-radius: 14px !important;
  object-fit: cover !important;
  object-position: center !important;
  background: #e5e7eb !important;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--jagwa-muted);
  font-size: 12px;
  font-weight: 900;
}

.candidate-card-body {
  flex: 1;
  min-width: 0;
}

.candidate-topline {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
}

.candidate-card strong {
  font-size: 17px;
  color: #111827;
}

.candidate-position {
  color: var(--jagwa-muted);
  font-size: 13px;
  margin-top: 4px;
}

.candidate-description {
  color: var(--jagwa-muted);
  font-size: 14px;
  line-height: 1.6;
  margin: 10px 0;
}

.read-more-btn {
  background: transparent !important;
  color: var(--jagwa-teal) !important;
  border: none !important;
  font-weight: 900;
  padding: 0 !important;
  cursor: pointer;
  box-shadow: none !important;
}

/* =========================================================
   RESULTS PAGE
========================================================= */

.print-my-votes {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 18px;
}

.result-summary,
.result-card {
  background: white !important;
  border: 1px solid var(--jagwa-border) !important;
  border-radius: 22px !important;
  box-shadow: var(--jagwa-shadow) !important;
  padding: 24px;
  margin-bottom: 18px;
}

.result-summary h4 {
  margin: 0 0 12px;
  font-weight: 900;
  color: var(--jagwa-text);
}

.result-summary p {
  margin: 6px 0;
  color: var(--jagwa-muted);
}

.candidate-result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18px;
}

.candidate-result-left {
  display: flex;
  align-items: center;
  gap: 14px;
}

.result-photo {
  width: 74px !important;
  height: 74px !important;
  min-width: 74px !important;
  max-width: 74px !important;
  border-radius: 14px !important;
  object-fit: cover !important;
  object-position: center !important;
  background: #e5e7eb !important;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--jagwa-muted);
  font-size: 11px;
  font-weight: 900;
}

.result-label {
  color: var(--jagwa-muted);
  font-size: 12px;
  font-weight: 800;
  margin-bottom: 4px;
}

.result-card h5 {
  margin: 0 0 10px;
  color: var(--jagwa-text);
  font-size: 20px;
  font-weight: 900;
}

.result-description,
.result-date {
  color: var(--jagwa-muted);
  font-size: 13px;
  margin-top: 6px;
}

.vote-locked-card {
  background: #fff7ed;
  border: 1px solid #fed7aa;
  color: #9a3412;
  border-radius: 22px;
  padding: 24px;
  box-shadow: var(--jagwa-shadow);
}

.vote-locked-card h3 {
  margin-top: 0;
  color: #9a3412;
  font-weight: 900;
}

.vote-locked-card p {
  line-height: 1.7;
}

.vote-locked-card a {
  display: inline-block;
  margin-top: 12px;
  background: #ea580c;
  color: white;
  text-decoration: none;
  padding: 12px 18px;
  border-radius: 14px;
  font-weight: 900;
}

/* =========================================================
   SUCCESS PAGE
========================================================= */

.success-box {
  max-width: 560px;
  margin: 80px auto;
  background: white;
  border: 1px solid var(--jagwa-border);
  border-radius: 28px;
  padding: 46px;
  text-align: center;
  box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
}

.success-icon {
  width: 96px;
  height: 96px;
  margin: 0 auto 24px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--jagwa-teal), var(--jagwa-teal-light));
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44px;
  font-weight: 900;
}

.success-box h1 {
  font-weight: 900;
  color: var(--jagwa-text);
  margin-bottom: 12px;
}

.success-box p {
  color: var(--jagwa-muted);
  margin-bottom: 24px;
}

/* =========================================================
   PRINT
========================================================= */

@media print {
  .voter-sidebar,
  .voter-topbar,
  .print-my-votes,
  #lastUpdated {
    display: none !important;
  }

  .voter-layout {
    display: block !important;
  }

  .voter-main {
    padding: 0 !important;
    background: white !important;
  }

  body {
    background: white !important;
  }

  .result-card,
  .result-summary {
    box-shadow: none !important;
    break-inside: avoid;
  }
}

/* =========================================================
   RESPONSIVE
========================================================= */

@media (max-width: 1100px) {
  .voter-layout {
    grid-template-columns: 1fr;
  }

  .voter-sidebar {
    position: relative;
    min-height: auto;
    border-right: none;
  }

  .candidate-grid,
  .dashboard-grid {
    grid-template-columns: 1fr;
  }

  .voter-topbar {
    flex-direction: column;
    align-items: flex-start;
  }

  #authStatus {
    width: 100%;
    justify-content: space-between;
  }

  .position-card-header {
    flex-direction: column;
    align-items: flex-start;
  }
}

@media (max-width: 700px) {
  .voter-main {
    padding: 20px;
  }

  .voter-topbar h1 {
    font-size: 28px;
  }

  .brand-box {
    gap: 12px !important;
    padding: 12px !important;
  }

  .brand-logo {
    width: 48px !important;
    height: 48px !important;
    min-width: 48px !important;
    max-width: 48px !important;
  }

  .brand-box h3 {
    font-size: 16px !important;
    letter-spacing: 3px !important;
  }

  .candidate-card {
    flex-direction: column;
  }

  .candidate-photo {
    width: 100% !important;
    height: 220px !important;
    min-width: 100% !important;
    max-width: 100% !important;
  }

  .candidate-topline {
    flex-direction: column;
  }

  .progress-content {
    flex-direction: column;
    align-items: flex-start;
  }

  .voter-profile-card {
    align-items: flex-start;
  }

  .voter-profile-actions {
    width: 100%;
    justify-content: space-between;
  }

  .candidate-result-left {
    align-items: flex-start;
  }
}