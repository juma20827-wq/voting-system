{% load static %}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>JAGWA SPORTS | Vote</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="{% static 'style.css' %}">
    <script src="{% static 'app.js' %}" defer></script>

    <style>
        body {
            animation: pageFade 0.55s ease;
        }

        @keyframes pageFade {
            from {
                opacity: 0;
                transform: translateY(14px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .voter-sidebar {
            animation: sidebarIn 0.6s ease;
        }

        @keyframes sidebarIn {
            from {
                opacity: 0;
                transform: translateX(-35px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .voter-main {
            animation: mainIn 0.65s ease;
        }

        @keyframes mainIn {
            from {
                opacity: 0;
                transform: translateY(25px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .brand-logo {
            width: 86px;
            height: 86px;
            object-fit: contain;
            border-radius: 18px;
        }

        .candidate-photo {
            width: 110px !important;
            height: 130px !important;
            min-width: 110px !important;
            max-width: 110px !important;
            object-fit: cover !important;
            object-position: center !important;
            border-radius: 14px !important;
            background: #e5e7eb !important;
        }

        .candidate-card {
            overflow: hidden !important;
        }

        .candidate-card img,
        #positions img {
            object-fit: cover !important;
            object-position: center !important;
        }

        @media (max-width: 640px) {
            .candidate-photo {
                width: 100% !important;
                height: 220px !important;
                max-width: 100% !important;
            }
        }
    </style>
</head>

<body>

<div class="voter-layout">

    <aside class="voter-sidebar">
        <div class="brand-box">
            <img src="{% static 'logo.png' %}" alt="JAGWA SPORTS" class="brand-logo">
            <h3>JAGWA<span>SPORTS</span></h3>
        </div>

        <nav class="voter-menu">
            <a href="/">🏠 Dashboard</a>
            <a href="/vote/" class="active">🗳️ Vote</a>
            <a href="/results/">✅ My Votes</a>
            <a href="/login/">🚪 Logout</a>
        </nav>

        <div class="vote-note">
            <strong>Your Vote is Important</strong>
            <p>You can vote once for each position. Make your choices count.</p>
        </div>
    </aside>

    <main class="voter-main">

        <div class="voter-topbar">
            <div>
                <h1>Vote for Your Candidates</h1>
                <p>Please select one candidate for each position.</p>
            </div>

            <div id="authStatus"></div>
        </div>

        <div id="voteProfile" class="result-summary p-4 rounded-4 shadow-sm mb-4 bg-white"></div>

        <div id="voteAlert" class="alert visually-hidden"></div>

        <section id="positions"></section>

    </main>

</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        if (window.pageInit) {
            window.pageInit('vote');
        }

        const observer = new MutationObserver(function () {
            document.querySelectorAll('#positions img').forEach(function (img) {
                img.classList.add('candidate-photo');
            });

            document.querySelectorAll('#positions .candidate-card').forEach(function (card) {
                card.style.overflow = 'hidden';
            });
        });

        observer.observe(document.getElementById('positions'), {
            childList: true,
            subtree: true
        });
    });
</script>

</body>
</html>